# =============================================================================
# HiOrg-Sync — Konfiguration
# =============================================================================
# 1. Diese Datei kopieren: cp .env.example .env
# 2. Alle Werte mit  <<<  ausfuellen (Pflichtfelder)
# 3. Optionale Werte koennen unveraendert bleiben
# =============================================================================


# -----------------------------------------------------------------------------
# HiOrg OAuth-Zugangsdaten  (vom HiOrg-Entwicklerportal)
# -----------------------------------------------------------------------------

# Client-ID und Secret aus dem HiOrg-App-Portal
HIORG_CLIENT_ID=<<<DEINE_CLIENT_ID>>>
HIORG_CLIENT_SECRET=<<<DEIN_CLIENT_SECRET>>>

# Callback-URL — muss EXAKT mit der im HiOrg-Portal hinterlegten URL uebereinstimmen
# Beispiel:  https://hiorg-sync.example.com/oauth/callback
#            http://192.168.1.10:8088/oauth/callback
HIORG_REDIRECT_URI=<<<https://deine-domain.de/oauth/callback>>>

# HiOrg API-Endpunkte (Standard — normalerweise nicht aendern)
HIORG_AUTH_URL=https://api.hiorg-server.de/oauth/v1/authorize
HIORG_TOKEN_URL=https://api.hiorg-server.de/oauth/v1/token
HIORG_API_BASE=https://api.hiorg-server.de/core/v1

# Berechtigungsumfang (Standard — normalerweise nicht aendern)
HIORG_SCOPE=openid personal:read personal:add personal:update


# -----------------------------------------------------------------------------
# Sicherheit
# -----------------------------------------------------------------------------

# Zufaelliger geheimer String fuer CSRF-Schutz des OAuth-Flows
# Mindestens 32 Zeichen, z.B. generiert mit:  openssl rand -hex 32
STATE_SECRET=<<<ZUFAELLIGER_LANGER_STRING>>>

# Geheimer String fuer UI-Session-Signierung (kann identisch mit STATE_SECRET sein)
UI_SESSION_SECRET=<<<ZUFAELLIGER_LANGER_STRING>>>


# -----------------------------------------------------------------------------
# Web-UI Zugang
# -----------------------------------------------------------------------------

# Passwort fuer die Web-Oberflaeche
UI_PASSWORD=<<<SICHERES_PASSWORT>>>

# Session-Gueltigkeitsdauer in Stunden (Standard: 12)
UI_SESSION_TTL_HOURS=12


# -----------------------------------------------------------------------------
# Organisationseinheiten (OVs)
# -----------------------------------------------------------------------------

# Komma-getrennte Liste der OV-Kuerzel die synchronisiert werden sollen
# Beispiel: OV_LIST=ov1,ov2,ov3
OV_LIST=<<<ov1>>>

# Wie viele Tage rueckwirkend beim allerersten Sync beruecksichtigt werden (Standard: 365)
INITIAL_SYNC_DAYS=365


# -----------------------------------------------------------------------------
# LDAP / Active Directory  (Pflichtfelder)
# -----------------------------------------------------------------------------

# LDAP-Server URL
# Beispiele:  ldap://dc.example.com        (unverschluesselt, Port 389)
#             ldaps://dc.example.com       (TLS, Port 636)
LDAP_URL=<<<ldap://dc.example.com>>>

# Bind-User (Service-Account mit Schreibrechten auf die Ziel-OUs)
# Beispiel:  CN=hiorg-sync,OU=Dienste,DC=example,DC=com
LDAP_BIND_USER=<<<CN=hiorg-sync,OU=Dienste,DC=example,DC=com>>>

# Passwort des Bind-Users
LDAP_BIND_PASSWORD=<<<PASSWORT>>>

# Standard-Domaene fuer UPN-Adressen, z.B.  example.com
LDAP_DEFAULT_DOMAIN=<<<example.com>>>


# -----------------------------------------------------------------------------
# LDAP / Active Directory  (Optionale Einstellungen)
# -----------------------------------------------------------------------------

# sAMAccountName-Quelle:
#   hiorg_username   -> verwendet den HiOrg-Benutzernamen (z.B. MustermannM)
#   vorname.nachname -> generiert max.mustermann (mit Eindeutigkeitspruefung)
LDAP_SAM_MODE=hiorg_username

# Nur aktive HiOrg-Mitglieder synchronisieren (empfohlen: true)
LDAP_ONLY_STATUS_ACTIVE=true

# Neue AD-Benutzer automatisch anlegen (Standard: false — erst testen!)
LDAP_CREATE_ENABLED=false

# Benutzer in neue OU verschieben wenn OV wechselt
LDAP_MOVE_IF_OU_CHANGED=true

# Leere LDAP-Felder mit HiOrg-Daten ueberschreiben (Standard: false = telefonbuchsicher)
LDAP_OVERWRITE_EMPTY=false

# Bestehenden sAMAccountName umbenennen wenn er sich aendert (Standard: false)
LDAP_UPDATE_SAM=false

# Organisationskuerzel die beim Sync ignoriert werden sollen (komma-getrennt)
# Beispiel:  EXCLUDE_ORGAKUERZEL=stab,eh
EXCLUDE_ORGAKUERZEL=stab

# Mitglieder aus AD-Gruppen entfernen wenn sie in HiOrg ausgetreten sind (Standard: false)
LDAP_GROUP_SYNC_REMOVE=false


# -----------------------------------------------------------------------------
# Optionale Erweiterungen
# -----------------------------------------------------------------------------

# API-Key fuer automatisierten Sync per curl/Cron
# Beispiel:  curl -X POST .../api/sync/ad/run -H "X-API-Key: <key>" -d "ov=ov1"
SYNC_API_KEY=<<<ZUFAELLIGER_API_KEY>>>

# HiOrg-ID in AD-Attribut speichern (z.B. fuer Nextcloud-Mapping)
# Standard-Attribut: msDS-cloudExtensionAttribute1
#LDAP_HIORG_ID_ATTR=msDS-cloudExtensionAttribute1
#LDAP_HIORG_ID_PREFIX=hiorg-

# Datenpfad (Standard fuer Docker: /var/lib/hiorg-sync — normalerweise nicht aendern)
#DATA_DIR=/var/lib/hiorg-sync
