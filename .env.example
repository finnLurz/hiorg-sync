# =============================================================================
# HiOrg-Sync — Konfiguration
# =============================================================================
# Anleitung:
#   1. Diese Datei kopieren:  cp .env.example .env
#   2. Die 6 leeren Felder ausfuellen (siehe Hinweise unten)
#   3. Alles weitere (LDAP, OVs, Mappings) wird nach dem Start in der
#      Web-Oberflaeche unter  http://<server-ip>:8088  eingestellt
# =============================================================================


# -----------------------------------------------------------------------------
# HiOrg OAuth — Zugangsdaten aus dem HiOrg-Entwicklerportal
# https://www.hiorg-server.de  →  Einstellungen → API / OAuth-Apps
# -----------------------------------------------------------------------------

HIORG_CLIENT_ID=
HIORG_CLIENT_SECRET=

# Die Callback-URL muss EXAKT so eingetragen sein wie im HiOrg-Portal hinterlegt.
# Beispiel mit eigenem Server:   https://hiorg-sync.meineverein.de/oauth/callback
# Beispiel im internen Netz:     http://192.168.1.10:8088/oauth/callback
HIORG_REDIRECT_URI=


# -----------------------------------------------------------------------------
# Sicherheitsschluessel — je ein langer zufaelliger Text (mind. 32 Zeichen)
#
# Einfachste Moeglichkeit: Passwort-Generator im Browser aufrufen,
# z.B. https://www.random.org/passwords/?num=1&len=40&format=plain
# oder einfach 40 zufaellige Buchstaben/Zahlen eintippen.
# Beide Werte sollten unterschiedlich sein.
# -----------------------------------------------------------------------------

STATE_SECRET=
UI_SESSION_SECRET=


# -----------------------------------------------------------------------------
# Passwort fuer die Web-Oberflaeche
# -----------------------------------------------------------------------------

UI_PASSWORD=
