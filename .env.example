# =============================================================================
# HiOrg-Sync — Konfiguration
# =============================================================================
# Anleitung:
#   1. Diese Datei kopieren:  cp .env.example .env
#   2. Abschnitt "PFLICHT" vollstaendig ausfuellen
#   3. Container starten, Rest in der Web-UI einstellen
# =============================================================================


# #############################################################################
# PFLICHT — Diese Werte MUESSEN vor dem ersten Start ausgefuellt werden
# #############################################################################


# -----------------------------------------------------------------------------
# HiOrg OAuth-App
# Wo finden?  HiOrg-Server → Verwaltung → API / OAuth-Apps → Neue App anlegen
# -----------------------------------------------------------------------------

HIORG_CLIENT_ID=
HIORG_CLIENT_SECRET=

# Die Callback-URL muss EXAKT so im HiOrg-Portal hinterlegt sein.
# Beispiel oeffentlich:  https://hiorg-sync.meineverein.de/oauth/callback
# Beispiel intern:       http://192.168.1.10:8088/oauth/callback
HIORG_REDIRECT_URI=


# -----------------------------------------------------------------------------
# Sicherheitsschluessel
# Je einen langen zufaelligen Text eingeben (mind. 32 Zeichen, beide verschieden).
# Generator:  https://www.random.org/passwords/?num=2&len=40&format=plain
# -----------------------------------------------------------------------------

STATE_SECRET=
UI_SESSION_SECRET=


# -----------------------------------------------------------------------------
# Web-UI Passwort
# -----------------------------------------------------------------------------

UI_PASSWORD=


# #############################################################################
# OPTIONAL — Standardwerte sind bereits eingetragen.
#            Nur aendern falls die eigene Umgebung abweicht.
#            LDAP, OVs und Mappings koennen alternativ auch in der Web-UI
#            unter  http://<server-ip>:8088  konfiguriert werden.
# #############################################################################


# -----------------------------------------------------------------------------
# HiOrg API-Endpunkte  (normalerweise unveraendert lassen)
# -----------------------------------------------------------------------------

HIORG_AUTH_URL=https://api.hiorg-server.de/oauth/v1/authorize
HIORG_TOKEN_URL=https://api.hiorg-server.de/oauth/v1/token
HIORG_API_BASE=https://api.hiorg-server.de/core/v1
HIORG_SCOPE=openid personal:read personal:add personal:update


# -----------------------------------------------------------------------------
# Organisationseinheiten
# Komma-getrennte OV-Kuerzel, z.B.:  OV_LIST=ov1,ov2,ov3
# Alternativ: in der Web-UI unter Einstellungen → OV-Liste eintragen
# -----------------------------------------------------------------------------

OV_LIST=

# Wie viele Tage rueckwirkend beim allerersten Sync beruecksichtigt werden
INITIAL_SYNC_DAYS=365


# -----------------------------------------------------------------------------
# LDAP / Active Directory
# Alternativ: in der Web-UI unter Einstellungen → LDAP-Verbindung eintragen
# -----------------------------------------------------------------------------

# LDAP-Server, z.B.:  ldap://dc.example.com  oder  ldaps://dc.example.com
LDAP_URL=

# Service-Account mit Schreibrechten, z.B.:  CN=sync,OU=Dienste,DC=example,DC=com
LDAP_BIND_USER=
LDAP_BIND_PASSWORD=

# UPN-Domaene, z.B.:  example.com
LDAP_DEFAULT_DOMAIN=


# -----------------------------------------------------------------------------
# LDAP-Verhalten  (Standardwerte sind fuer den normalen Betrieb empfohlen)
# -----------------------------------------------------------------------------

# sAMAccountName-Quelle:  hiorg_username (z.B. MustermannM)  oder  vorname.nachname
LDAP_SAM_MODE=hiorg_username

# Nur aktive Mitglieder synchronisieren
LDAP_ONLY_STATUS_ACTIVE=true

# Neue AD-Benutzer automatisch anlegen  (erst auf false testen!)
LDAP_CREATE_ENABLED=false

# Benutzer in neue OU verschieben wenn OV wechselt
LDAP_MOVE_IF_OU_CHANGED=true

# Leere AD-Felder mit HiOrg-Daten ueberschreiben  (false = telefonbuchsicher)
LDAP_OVERWRITE_EMPTY=false

# Mitglieder aus AD-Gruppen entfernen wenn in HiOrg ausgetreten
LDAP_GROUP_SYNC_REMOVE=false

# Orgakuerzel die beim Sync ignoriert werden sollen  (komma-getrennt)
EXCLUDE_ORGAKUERZEL=stab


# -----------------------------------------------------------------------------
# Erweitert / Selten benoetigt
# Hinweis: Auskommentierte Zeilen (# am Anfang) sind deaktiviert.
#          Der dahinter stehende Wert ist der Standardwert, der automatisch
#          verwendet wird — nur einkommentieren und aendern falls noetig.
# -----------------------------------------------------------------------------

# API-Key fuer automatisierten Sync per Cron-Job oder Skript.
# Ohne diesen Key kann /api/sync/ad/run nur per UI-Session aufgerufen werden.
# Sinnvoll wenn der Sync z.B. nachts automatisch laufen soll.
# Beispiel:  curl -X POST http://server:8088/api/sync/ad/run \
#                 -H "X-API-Key: WERT" -d "ov=ov1"
SYNC_API_KEY=

# HiOrg-ID in einem AD-Attribut speichern.
# Benoetigt wenn ein weiteres System (z.B. Nextcloud) die HiOrg-ID aus dem AD
# lesen soll, um Benutzer zuzuordnen. Das Attribut muss im AD-Schema vorhanden
# sein. Der Standardwert (msDS-cloudExtensionAttribute1) ist in den meisten
# Windows-AD-Umgebungen bereits verfuegbar.
# Auskommentiert = Standardwerte werden automatisch verwendet.
#LDAP_HIORG_ID_ATTR=msDS-cloudExtensionAttribute1
#LDAP_HIORG_ID_PREFIX=hiorg-

# Datenpfad fuer persistente Daten (Tokens, Einstellungen, Sync-Marker).
# Im Docker-Betrieb wird dieser Pfad als Volume eingebunden — nicht aendern
# ausser du weisst was du tust oder nutzt keine Docker-Compose-Datei.
# Auskommentiert = Standardwert /var/lib/hiorg-sync wird verwendet.
#DATA_DIR=/var/lib/hiorg-sync

# Wie lange eine Web-UI-Session gueltig bleibt (in Stunden).
# Nach Ablauf muss sich der Benutzer erneut einloggen.
# Auskommentiert = Standardwert 12 Stunden wird verwendet.
#UI_SESSION_TTL_HOURS=12
