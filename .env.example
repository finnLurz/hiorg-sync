# =============================================================================
# HiOrg-Sync — Minimalkonfiguration
# =============================================================================
# 1. Datei kopieren:  cp .env.example .env
# 2. Alle 6 Werte ausfuellen
# 3. Alles weitere (LDAP, OVs, Mappings) wird in der Web-UI eingestellt
# =============================================================================


# --- HiOrg OAuth-App (aus dem HiOrg-Entwicklerportal) -----------------------

HIORG_CLIENT_ID=
HIORG_CLIENT_SECRET=

# Muss EXAKT mit der im HiOrg-Portal eingetragenen Redirect-URL uebereinstimmen
# Beispiel: https://hiorg-sync.example.com/oauth/callback
HIORG_REDIRECT_URI=


# --- Sicherheit (jeweils einen langen zufaelligen String eintragen) ----------
# Tipp: openssl rand -hex 32

STATE_SECRET=
UI_SESSION_SECRET=


# --- Web-UI Zugang -----------------------------------------------------------

UI_PASSWORD=
